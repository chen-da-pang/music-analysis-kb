# Copy to .env for a local/manual workspace run and edit values as needed.

# Directory containing input audio files inside the workspace.
AUDIO_ROOT=data/input

# Persistent-output root. CNB pipelines set this to /workspace/cache/output/music_flamingo_pipeline.
WORK_DIR=data/output/music_flamingo_pipeline

# Logical output group and unique run identity. CNB supplies CNB_BUILD_ID automatically;
# set MUSIC_FLAMINGO_RUN_ID manually before rerunning in the same local/Dev GPU workspace.
MUSIC_FLAMINGO_OUTPUT_NAME=devgpu_batch
# MUSIC_FLAMINGO_RUN_ID=manual-20260710-001

# Optional Hugging Face mirror for model/weight downloads during candidate-image rebuilds.
# HF_ENDPOINT=https://hf-mirror.com

# Preloaded model paths in the promoted CNB Docker Artifact image.
MUSIC_FLAMINGO_MODEL=nvidia/music-flamingo-think-2601-hf
MUSIC_FLAMINGO_REVISION=1ea2109
MUSIC_FLAMINGO_MODEL_DIR=/opt/models/music-flamingo-think-2601-hf

# Final-analysis contract: do not lower these values in normal production runs.
MUSIC_FLAMINGO_MAX_NEW_TOKENS=2048
MUSIC_FLAMINGO_AUDIO_CLIP_SECONDS=240

# Optional. Remote pipelines default this to 0 to avoid diagnostic CUDA fences on every
# item; set to 1 only while investigating GPU-memory behavior.
MUSIC_FLAMINGO_DETAILED_CUDA_TELEMETRY=0

# Optional override. Leave unset to use the final-analysis default prompt.
# MUSIC_FLAMINGO_PROMPT=Describe this track in full detail...

# Dev GPU batch size. Keep a single workspace alive only while processing grouped work,
# then stop it immediately to avoid idle GPU billing.
MUSIC_FLAMINGO_BATCH_LIMIT=10
